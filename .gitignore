# Block proprietary engines from leaving the local machine
*.py
*.pyc
__pycache__/
.pycache_compile/
.DS_Store
*.csv
*.pem
*.jsonl
.env
secrets/
data/private/
hvl_bundle.md
.firebase/

# Only allow safe web/config files to be pushed
!.gitignore
!.env.example
!firebase.json
!.firebaserc
!.gitattributes
!web/
!web/**
!web/data/
!web/data/public_feed.json
